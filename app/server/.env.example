PORT=5050
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/ner_app

# JWT
JWT_SECRET=please_change_me
JWT_EXPIRES_IN=7d

# Passwordless login codes (OTP)
# NOTE: In 'auto' mode, the server will ERROR if SMTP isn't configured.
# Use LOGIN_CODE_DELIVERY=log for local/dev to print codes to the server console.
LOGIN_CODE_SECRET=please_change_me_too
LOGIN_CODE_TTL_MINUTES=10
LOGIN_CODE_RESEND_SECONDS=30
# auto | log
LOGIN_CODE_DELIVERY=log

# Email (SMTP)
# Gmail example (recommended: create a Google "App Password" and use it as SMTP_PASS):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_16_char_app_password
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@ner.local

# CORS
CLIENT_ORIGIN=http://localhost:5173

# AI service
AI_SERVICE_URL=http://localhost:8000
